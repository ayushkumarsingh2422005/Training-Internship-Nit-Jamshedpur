# Copy to .env.local and fill in values
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>

# Random secret for signed student sessions (min 16 chars). Example: openssl rand -base64 32
SESSION_SECRET=your-long-random-secret-here

# Admin dashboard login (/admin) — keep these private
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# Public site URL for SEO, sitemap, and Open Graph (no trailing slash)
# Example: https://internship.nitjsr.ac.in
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# Optional: Google Search Console verification token
# GOOGLE_SITE_VERIFICATION=your-google-verification-code
